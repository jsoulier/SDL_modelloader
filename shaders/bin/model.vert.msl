#pragma clang diagnostic ignored "-Wmissing-prototypes"

#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct t_matrix
{
    float4x4 u_matrix;
};

struct main0_out
{
    float2 o_uv [[user(locn0)]];
    float4 gl_Position [[position]];
};

struct main0_in
{
    uint i_packed [[attribute(0)]];
    float i_texcoord [[attribute(1)]];
    float3 i_position [[attribute(2)]];
    float i_yaw [[attribute(3)]];
};

static inline __attribute__((always_inline))
float3 voxel_get_position(thread const uint& _packed)
{
    int3 direction;
    direction.x = 1 - (2 * int((_packed >> uint(7)) & 1u));
    direction.y = 1 - (2 * int((_packed >> uint(15)) & 1u));
    direction.z = 1 - (2 * int((_packed >> uint(23)) & 1u));
    int3 magnitude;
    magnitude.x = int((_packed >> uint(0)) & 127u);
    magnitude.y = int((_packed >> uint(8)) & 127u);
    magnitude.z = int((_packed >> uint(16)) & 127u);
    return float3(magnitude * direction);
}

vertex main0_out main0(main0_in in [[stage_in]], constant t_matrix& _137 [[buffer(0)]])
{
    main0_out out = {};
    float cos_yaw = cos(in.i_yaw);
    float sin_yaw = sin(in.i_yaw);
    float3x3 rotation = float3x3(float3(float3(cos_yaw, 0.0, sin_yaw)), float3(0.0, 1.0, 0.0), float3(float3(-sin_yaw, 0.0, cos_yaw)));
    uint param = in.i_packed;
    float3 o_position = in.i_position + (rotation * voxel_get_position(param));
    out.o_uv = float2(in.i_texcoord, 0.5);
    out.gl_Position = _137.u_matrix * float4(o_position, 1.0);
    return out;
}

